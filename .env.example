# ================================================================
# ContaFácil — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el .env real a GitHub
# ================================================================

# ── Supabase ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ── Stripe ────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Anthropic (Conta IA) — solo en Edge Functions, nunca en frontend
# ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (emails) ───────────────────────────────────────────────
# RESEND_API_KEY=re_...

# ── Twilio (WhatsApp) ─────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── App ───────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=ContaFácil
